{
  "manifest_version": 3,
  "name": "Meet AI Transcriber",
  "version": "1.0",
  "description": "Transcrição automática do Google Meet",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms",
    "tabCapture",
    "offscreen"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "https://transcription-1pcy.onrender.com/*",
    "https://qa-gray.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:5173/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Meet Transcriber"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://qa-gray.vercel.app/*", "http://localhost:3000/*", "http://localhost:5173/*"],
      "js": ["session-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}