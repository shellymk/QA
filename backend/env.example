PORT=3000
# HOST: 127.0.0.1 (padrão, só localhost). Use 0.0.0.0 para expor na rede (com cuidado).
HOST=127.0.0.1
MONGO_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster.mongodb.net/meetai
BOT_STORAGE_STATE=bot-auth.json
NODE_ENV=development

# Segurança (OBRIGATÓRIOS — o servidor não sobe sem eles).
# AUTH0_DOMAIN + AUTH0_AUDIENCE: o backend valida o token do Auth0 com eles.
#   DOMAIN  = Auth0 Dashboard -> Settings -> General -> Domain (ex.: dev-xxxx.uk.auth0.com)
#   AUDIENCE = Auth0 Dashboard -> APIs -> sua API -> "Identifier" (ex.: https://api.meetai)
# EXTENSION_API_KEY: chave da extensão/bot (rota de máquina, sem login). Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH0_DOMAIN=dev-xxxx.uk.auth0.com
AUTH0_AUDIENCE=https://api.meetai
EXTENSION_API_KEY=troque_por_um_valor_aleatorio_longo
# Origens web permitidas (CORS), separadas por vírgula. Padrão já inclui
# localhost:PORT e localhost:5173 (Vite). Em produção aponte pro painel na Vercel.
# ALLOWED_ORIGINS=https://qa-gray.vercel.app

# STT + diarização (Caminho B — separa quem falou). Opcional: só é preciso
# para transcrever áudio. Pegue em https://www.assemblyai.com (Dashboard → API Keys).
ASSEMBLYAI_API_KEY=

# Credenciais do bot Google — necessarias para relogin automatico
# quando a sessao expirar (bot-auth.json desatualizado)
BOT_EMAIL=seu_email_do_bot@gmail.com
BOT_PASSWORD=sua_senha_do_bot

# NOTA: o painel (frontend) tambem precisa dos valores do Auth0, mas em
# frontend/.env.local (VITE_AUTH0_DOMAIN / VITE_AUTH0_CLIENT_ID / VITE_AUTH0_AUDIENCE).
# O envio de email (confirmacao/reset) sai pelo Gmail do bot via SMTP configurado
# DENTRO do painel do Auth0 (Branding -> Email Provider) — nao entra neste .env.