PORT=3000
# HOST: 127.0.0.1 (padrão, só localhost). Use 0.0.0.0 para expor na rede (com cuidado).
HOST=127.0.0.1
MONGO_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster.mongodb.net/meetai
BOT_STORAGE_STATE=bot-auth.json
NODE_ENV=development

# Segurança (OBRIGATÓRIOS — o servidor não sobe sem eles).
# Gere cada valor com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_um_valor_aleatorio_longo
EXTENSION_API_KEY=troque_por_outro_valor_aleatorio_longo
# Origens web permitidas (CORS), separadas por vírgula. Padrão: localhost:PORT.
# ALLOWED_ORIGINS=http://localhost:3000

# STT + diarização (Caminho B — separa quem falou). Opcional: só é preciso
# para transcrever áudio. Pegue em https://www.assemblyai.com (Dashboard → API Keys).
ASSEMBLYAI_API_KEY=

# Credenciais do bot Google — necessarias para relogin automatico
# quando a sessao expirar (bot-auth.json desatualizado)
BOT_EMAIL=seu_email_do_bot@gmail.com
BOT_PASSWORD=sua_senha_do_bot

# ================================================================
# PENDENTE — Auth0 (login/cadastro/Google/reset ficam por conta do Auth0)
# ================================================================
# Auth0 Dashboard -> Applications -> "Single Page Application": Domain + Client ID.
# Auth0 Dashboard -> APIs -> criar API -> "Identifier" = AUDIENCE.
# O backend so VALIDA o token (DOMAIN + AUDIENCE); nao precisa de client secret.
AUTH0_DOMAIN=
AUTH0_AUDIENCE=