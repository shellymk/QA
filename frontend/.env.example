# URL do backend (Render em produção). Sem a barra final.
# Em dev, deixe em branco/localhost que o painel usa http://localhost:3000.
VITE_API_URL=

# Auth0 no painel React (Vite exige o prefixo VITE_).
# Estes valores são PÚBLICOS (vão pro bundle do navegador) — não são segredo.
# Copie este arquivo para .env.local e preencha com os dados da sua
# "Single Page Application" no Auth0 (Dashboard -> Applications).
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
# Identifier da sua API no Auth0 (Dashboard -> APIs) — mesmo valor do AUDIENCE do backend.
VITE_AUTH0_AUDIENCE=
